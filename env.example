# ── Obrigatórias ──────────────────────────────────────────────
# Token do bot criado no @BotFather
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Seu Telegram ID (para receber convites e comandos admin)
# Descubra o seu falando com @userinfobot
ADMIN_TELEGRAM_ID=123456789

# ── Opcionais ─────────────────────────────────────────────────
# Intervalo entre checagens em segundos (padrão: 120 = 2 minutos)
CHECK_INTERVAL_SECONDS=120

# Caminho do banco SQLite (padrão: fiscal.db na raiz)
DB_PATH=fiscal.db
